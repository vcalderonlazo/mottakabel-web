---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---
<Layout title="Inicio">
  <Hero />

  <section class="nosotros-intro">
    <div class="container nosotros-inner">
      <span class="eyebrow">Nosotros</span>
      <h2>No solo tenemos el producto correcto. Garantizamos que tu proyecto no se detenga.</h2>
      <p class="lead">
        Somos <strong>consultores técnicos en cables industriales</strong>, respaldados
        por marcas de primer nivel. Trabajamos en los sectores de minería, energía, pesca y construcción a elegir la
        solución correcta y a recibirla a tiempo — sin sorpresas, sin retrasos.
      </p>
      <div class="cta-row">
        <a href="/productos" class="btn btn-primary">Ver catálogo</a>
        <a href="/contacto" class="btn btn-secondary">Contáctanos</a>
      </div>
    </div>
  </section>

  <section class="sectores">
    <div class="container">
      <span class="eyebrow eyebrow-dark">El mejor portafolio de soluciones de cables por</span>
      <h2 class="sectores-title">Sectores</h2>

      <div class="sectores-grid">
        <a href="/productos" class="sector-card" style="background-image: url(/img/sectores/mineria.jpg)">
          <div class="sector-overlay"></div>
          <div class="sector-text">
            <h3>Minería</h3>
            <p>Cables de media tensión, control e instrumentación para operaciones superficiales y subterráneas.</p>
          </div>
        </a>

        <a href="/productos" class="sector-card" style="background-image: url(/img/sectores/energia.jpg)">
          <div class="sector-overlay"></div>
          <div class="sector-text">
            <h3>Energía</h3>
            <p>Soluciones para generación, transmisión y distribución eléctrica de alta exigencia.</p>
          </div>
        </a>

        <a href="/productos" class="sector-card" style="background-image: url(/img/sectores/pesca.jpg)">
          <div class="sector-overlay"></div>
          <div class="sector-text">
            <h3>Pesca</h3>
            <p>Cables resistentes a ambientes salinos para embarcaciones y plantas pesqueras.</p>
          </div>
        </a>

        <a href="/productos" class="sector-card" style="background-image: url(/img/sectores/construccion.jpg)">
          <div class="sector-overlay"></div>
          <div class="sector-text">
            <h3>Construcción</h3>
            <p>Cableado eléctrico y de control para proyectos de infraestructura y edificación.</p>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .eyebrow {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--orange-dark);
    margin-bottom: 12px;
  }

  .eyebrow-dark {
    color: var(--gray-text);
    text-align: center;
    font-size: 12px;
  }

  .nosotros-intro {
    background: var(--cream);
    padding: 64px 0;
  }

  .nosotros-inner {
    max-width: 720px;
  }

  .nosotros-intro h2 {
    font-size: 30px;
    line-height: 1.3;
    margin-bottom: 18px;
  }

  .lead {
    font-size: 16.5px;
    color: var(--dark-text);
    line-height: 1.7;
  }

  .cta-row {
    margin-top: 28px;
    display: flex;
    gap: 16px;
  }

  .btn {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.5px;
    padding: 14px 28px;
    border-radius: 6px;
    display: inline-block;
  }

  .btn-primary {
    background: var(--orange);
    color: var(--orange-dark);
  }

  .btn-secondary {
    border: 1.5px solid var(--navy);
    color: var(--navy);
  }

  .sectores {
    background: #ffffff;
    padding: 70px 0;
    text-align: center;
  }

  .sectores-title {
    font-size: 34px;
    margin-bottom: 40px;
  }

  .sectores-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    text-align: left;
  }

  .sector-card {
    position: relative;
    height: 260px;
    border-radius: 10px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-color: var(--navy);
    display: flex;
    align-items: flex-end;
  }

  .sector-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(4,44,83,0.92) 10%, rgba(4,44,83,0.15) 70%);
  }

  .sector-text {
    position: relative;
    z-index: 2;
    padding: 20px;
  }

  .sector-text h3 {
    color: #ffffff;
    font-size: 20px;
    margin-bottom: 6px;
  }

  .sector-text p {
    color: var(--blue-light);
    font-size: 12.5px;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .sectores-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .sectores-grid {
      grid-template-columns: 1fr;
    }
    .nosotros-intro h2 {
      font-size: 24px;
    }
  }
</style>