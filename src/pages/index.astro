---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Inicio">
  <section class="hero">
    <div class="container hero-inner">
      <h1>Cables industriales para <span class="accent">minería</span>, energía, pesca y construcción</h1>
      <p class="lead">
        Más que un proveedor, somos tu <strong>consultor técnico en cables</strong>:
        expertos en la industria que garantizan la continuidad operativa de tus proyectos.
      </p>
      <div class="cta-row">
        <a href="/productos" class="btn btn-primary">Ver catálogo</a>
        <a href="/contacto" class="btn btn-secondary">Contáctanos</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: var(--navy);
    color: #ffffff;
    padding: 100px 0;
  }

  .hero-inner {
    max-width: 700px;
  }

  .hero h1 {
    color: #ffffff;
    font-size: 42px;
    line-height: 1.3;
  }

  .accent {
    color: var(--orange);
  }

  .lead {
    margin-top: 24px;
    font-size: 17px;
    color: var(--blue-light);
    line-height: 1.7;
  }

  .cta-row {
    margin-top: 36px;
    display: flex;
    gap: 16px;
  }

  .btn {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.5px;
    padding: 14px 28px;
    border-radius: 6px;
    display: inline-block;
  }

  .btn-primary {
    background: var(--orange);
    color: var(--orange-dark);
  }

  .btn-secondary {
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    color: #ffffff;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 30px;
    }
  }
</style>