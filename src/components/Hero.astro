---
const slides = [
  {
    image: "/img/hero/transmision.jpg",
    text: "Conectamos soluciones eléctricas, industriales, mineras e hidrocarburos",
  },
  {
    image: "/img/hero/cables.jpg",
    text: "Distribuidor especializado en cables para entornos críticos: minería, pesca, offshore e industria pesada",
  },
  {
    image: "/img/hero/mina.jpg",
    text: "Más que un proveedor, somos consultores técnicos que garantizan la continuidad de tu proyecto",
  },
  {
    image: "/img/hero/maquina.jpg",
    text: "Respaldados por experiencia y compromiso con cada proyecto",
  },
];
---
<section class="hero-carousel" aria-label="Presentación Motta Kabel">
  <div class="slides">
    {slides.map((slide, i) => (
      <div class={`slide ${i === 0 ? "active" : ""}`} style={`background-image: url(${slide.image})`}>
        <div class="overlay"></div>
        <div class="container slide-text-wrap">
          <p class="slide-text">{slide.text}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="dots">
    {slides.map((_, i) => (
      <button class={`dot ${i === 0 ? "active" : ""}`} data-index={i} aria-label={`Ir a la diapositiva ${i + 1}`}></button>
    ))}
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    width: 100%;
    height: 62vh;
    min-height: 420px;
    overflow: hidden;
  }

  .slides {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-color: var(--navy);
    opacity: 0;
    transition: opacity 1s ease;
    display: flex;
    align-items: flex-end;
  }

  .slide.active {
    opacity: 1;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(4, 44, 83, 0.85) 0%, rgba(4, 44, 83, 0.25) 55%, rgba(4, 44, 83, 0.45) 100%);
  }

  .slide-text-wrap {
    position: relative;
    z-index: 2;
    padding-bottom: 64px;
  }

  .slide-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 32px;
    line-height: 1.35;
    color: #ffffff;
    max-width: 640px;
    letter-spacing: 0.3px;
  }

  .dots {
    position: absolute;
    bottom: 22px;
    right: 5%;
    z-index: 3;
    display: flex;
    gap: 10px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    background: transparent;
    cursor: pointer;
    padding: 0;
  }

  .dot.active {
    background: var(--orange);
    border-color: var(--orange);
  }

  @media (max-width: 640px) {
    .hero-carousel {
      height: 52vh;
      min-height: 340px;
    }
    .slide-text {
      font-size: 22px;
    }
  }
</style>

<script>
  const slides = document.querySelectorAll(".hero-carousel .slide");
  const dots = document.querySelectorAll(".hero-carousel .dot");
  let current = 0;
  let timer;

  function goTo(index) {
    slides[current].classList.remove("active");
    dots[current].classList.remove("active");
    current = index;
    slides[current].classList.add("active");
    dots[current].classList.add("active");
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  function startAutoplay() {
    timer = setInterval(next, 5000);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      clearInterval(timer);
      goTo(i);
      startAutoplay();
    });
  });

  startAutoplay();
</script>