---
const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/productos", label: "Productos" },
  { href: "/contacto", label: "Contacto" },
];
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/img/logo.png" alt="Motta Kabel" class="logo-img" />
    </a>

    <nav class="nav">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid #e5e3db;
    padding: 18px 0;
    position: sticky;
    top: 0;
    background: #ffffff;
    z-index: 50;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 30px;
    width: auto;
    display: block;
  }

  .nav {
    display: flex;
    gap: 32px;
  }

  .nav a {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: var(--dark-text);
  }

  .nav a:hover {
    color: var(--orange-dark);
  }

  @media (max-width: 640px) {
    .nav {
      gap: 16px;
    }
    .nav a {
      font-size: 13px;
    }
  }
</style>