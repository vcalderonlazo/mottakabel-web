---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo">
        <span class="letter">M</span>
        <svg class="ring" width="22" height="22" viewBox="-11 -11 22 22">
          <circle r="9.3" fill="#EF9F27" />
          <circle r="6.5" fill="#042C53" />
          <circle r="3.3" fill="#85B7EB" />
          <circle r="1.3" fill="#EF9F27" />
        </svg>
        <span class="letter">TTA</span>
        <span class="kabel">KABEL</span>
      </a>
      <p class="tagline">Consultores técnicos en cables industriales</p>
    </div>

    <div class="footer-contact">
      <a href="tel:+51961600733">+51 961 600 733</a>
      <a href="mailto:contacto@mottakabel.com">contacto@mottakabel.com</a>
      <span>mottakabel.com</span>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; {year} Motta Kabel. Todos los derechos reservados.</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: #ffffff;
    padding: 40px 0 20px;
    margin-top: 80px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .footer-brand .logo {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .footer-brand .letter {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    color: #ffffff;
    letter-spacing: 1px;
  }

  .footer-brand .kabel {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    color: #ffffff;
    letter-spacing: 3px;
    margin-left: 8px;
  }

  .tagline {
    font-size: 13px;
    color: var(--blue-light);
    margin-top: 8px;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 14px;
  }

  .footer-contact a,
  .footer-contact span {
    color: var(--blue-light);
  }

  .footer-contact a:hover {
    color: var(--orange);
  }

  .footer-bottom {
    padding-top: 16px;
    font-size: 12px;
    color: var(--blue-light);
    opacity: 0.7;
  }
</style>